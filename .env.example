# Copy to .env and fill in. .env is gitignored.

# --- LiteLLM ---
LITELLM_MASTER_KEY=sk-1234        # change in production

# --- Prisma AIRS (required) ---
AIRS_API_KEY=                     # x-pan-token from Strata Cloud Manager
AIRS_API_PROFILE_NAME=            # your AIRS security profile name

# --- Azure OpenAI (for the azure-gpt-4.1 model) ---
AZURE_API_BASE=https://<your-resource>.openai.azure.com
AZURE_API_KEY=
AZURE_API_VERSION=2025-01-01-preview

# --- AWS Bedrock (for the bedrock-claude model) ---
# Option A: env vars
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Option B: mount ~/.aws into the container (see docker-compose.yml)

# --- Anthropic direct (optional) ---
ANTHROPIC_API_KEY=

# --- Local verification harness only (litellm-config.local-test.yaml) ---
OPENAI_API_KEY=
